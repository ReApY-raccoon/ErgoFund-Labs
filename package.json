{
	"name": "bene-fundraising",
	"version": "0.0.1",
	"private": true,
	"keywords": ["ergo", "fundraising", "blockchain", "sveltekit", "aossie"],
	"description": "Bene Fundraising Platform on Ergo blockchain - Multi-token support, referrals, analytics",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
	},
	"devDependencies": {
		"@eslint/js": "^9.0.0",
		"@sveltejs/adapter-node": "^5.0.0",
		"@sveltejs/kit": "^2.10.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.0.0",
		"eslint-plugin-svelte": "^2.36.0",
		"jest": "^29.7.0",
		"prettier": "^3.0.0",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"ts-jest": "^29.2.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^5.4.0"
	},
	"dependencies": {
		"@fleet-sdk/core": "^0.12.0"
	}
}
