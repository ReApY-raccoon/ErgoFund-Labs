# Copy to .env and fill in. Never commit real secrets.

# --- Public (safe in client bundles if prefixed with PUBLIC_ in SvelteKit) ---
# Ergo node or explorer base (NO hardcoding in source — use env)
PUBLIC_ERGO_NETWORK=mainnet
# Example testnet explorer API base:
# PUBLIC_ERGO_EXPLORER_URL=https://api-testnet.ergoplatform.com

# Compiled campaign contract ErgoTree hex (when building real txs)
# PUBLIC_BENE_CAMPAIGN_ERGOTREE=

# --- Server-only (API routes / Docker backend) ---
# ERGO_NODE_URL=
# Required for `npm run dev:backend`. Matches `infra/docker-compose.yml` db service on the host.
DATABASE_URL=postgresql://bene:bene@localhost:5432/bene

# --- Deployment (document actual URLs in README after deploy) ---
# PUBLIC_APP_URL=https://your-frontend.example.com
# PUBLIC_API_URL=https://your-api.example.com
